# ─────────────────────────────────────────────────────────────
#  AbFLow — Configuration
#  Copie ce fichier en .env et remplis les valeurs avant de déployer
# ─────────────────────────────────────────────────────────────

# ── Authentification ──────────────────────────────────────────
AUTH_USERNAME=admin
# Mot de passe en clair — le serveur le hash en bcrypt au démarrage
# Choisir un mot de passe fort (20+ caractères aléatoires) :
#   openssl rand -base64 20
AUTH_PASSWORD=change_me_strong_password

# Clé secrète pour signer les tokens JWT (minimum 32 caractères aléatoires)
# Génère-en une avec : openssl rand -hex 32
JWT_SECRET=change_me_very_long_random_secret

# ── CORS ──────────────────────────────────────────────────────
# Origines autorisées, séparées par des virgules.
# Inclure l'URL d'AbView pour que le screensaver puisse appeler l'API.
# Exemple : http://localhost:5173,http://192.168.1.10:8080
CORS_ORIGIN=http://localhost:5173

# ── API Key (lecture externe — ABVIEW, etc.) ──────────────────
# Génère-en une avec :
#   node -e "const c=require('crypto');console.log('abf_'+c.randomBytes(32).toString('hex'))"
API_KEY=

# ── Stockage ──────────────────────────────────────────────────
STORAGE_TYPE=local

# Stockage local — chemin sur l'hôte (Raspberry Pi)
UPLOADS_PATH=./uploads

# Stockage SFTP (décommenter si STORAGE_TYPE=sftp)
# SFTP_HOST=192.168.1.50
# SFTP_PORT=22
# SFTP_USER=abflow
# SFTP_PASSWORD=mot_de_passe_ssh
# SFTP_KEY_PATH=/run/secrets/id_rsa
# SFTP_PATH=/srv/abflow/uploads

# ── Quota de stockage (optionnel) ────────────────────────────
# Limite l'espace total en Mo. Laisser vide pour illimité.
# STORAGE_QUOTA_MB=10000

# ── Nom de l'application (affiché dans l'interface) ──────────
VITE_APP_NAME=AbFlow

# ── Nom de l'instance (optionnel) ─────────────────────────────
# Utile quand plusieurs instances d'AbFlow tournent sur des sites différents
# (même nom d'app partout) — affiché sous le nom de l'app sur l'écran de connexion
# pour distinguer les déploiements. Ex : "Maison", "Bureau", "Chalet".
VITE_INSTANCE_NAME=
